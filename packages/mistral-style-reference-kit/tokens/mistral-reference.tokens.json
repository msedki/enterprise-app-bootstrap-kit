  "typography": {
    "fontFamily": {
      "sans": {
        "$type": "fontFamily",
        "$value": [
          "Arial",
          "ui-sans-serif",
          "system-ui",
          "sans-serif"
        ]
      },
      "mono": {
        "$type": "fontFamily",
        "$value": [
          "SF Mono",
          "ui-monospace",
          "Menlo",
          "Monaco",
          "Consolas",
          "monospace"
        ]
      }
    },
    "weight": {
      "regular": {
        "$type": "fontWeight",
        "$value": 400
      },
      "medium": {
        "$type": "fontWeight",
        "$value": 500
      },
      "semibold": {
        "$type": "fontWeight",
        "$value": 600
      },
      "bold": {
        "$type": "fontWeight",
        "$value": 700
      },
      "black": {
        "$type": "fontWeight",
        "$value": 900
      }
    },
    "scale": {
      "xs": {
        "fontSize": "0.75rem",
        "lineHeight": 1.4,
        "letterSpacing": "-0.01em"
      },
      "sm": {
        "fontSize": "0.875rem",
        "lineHeight": 1.4,
        "letterSpacing": "-0.015em"
      },
      "base": {
        "fontSize": "1rem",
        "lineHeight": 1.5,
        "letterSpacing": "-0.02em"
      },
      "lg": {
        "fontSize": "1.125rem",
        "lineHeight": 1.4,
        "letterSpacing": "-0.02em"
      },
      "xl": {
        "fontSize": "1.25rem",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em"
      },
      "2xl": {
        "fontSize": "1.5rem",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em"
      },
      "3xl": {
        "fontSize": "1.875rem",
        "lineHeight": 1.2,
        "letterSpacing": "-0.02em"
      },
      "4xl": {
        "fontSize": "2.25rem",
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      },
      "5xl": {
        "fontSize": "3rem",
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      },
      "6xl": {
        "fontSize": "3.5rem",
        "lineHeight": 1.1,
        "letterSpacing": "-0.04em"
      }
    }
  },
  "dimension": {
    "radius": {
      "base": {
        "$type": "dimension",
        "$value": "0.625rem"
      },
      "sm": {
        "$type": "dimension",
        "$value": "0.375rem"
      },
      "md": {
        "$type": "dimension",
        "$value": "0.5rem"
      },
      "lg": {
        "$type": "dimension",
        "$value": "0.625rem"
      },
      "xl": {
        "$type": "dimension",
        "$value": "0.875rem"
      }
    },
    "layout": {
      "headerDesktop": {
        "$type": "dimension",
        "$value": "4.5rem"
      },
      "headerMobile": {
        "$type": "dimension",
        "$value": "3.375rem"
      },
      "sidebar": {
        "$type": "dimension",
        "$value": "16rem"
      },
      "contentInset": {
        "$type": "dimension",
        "$value": "4rem"
      },
      "outerInset": {
        "$type": "dimension",
        "$value": "1rem"
      },
      "maxCanvas": {
        "$type": "dimension",
        "$value": "120rem"
      }
    },
    "icon": {
      "canvas": {
        "$type": "dimension",
        "$value": "24px"
      },
      "module": {
        "$type": "dimension",
        "$value": "3px"
      },
      "default": {
        "$type": "dimension",
        "$value": "16px"
      }
    }
  },
  "motion": {
    "duration": {
      "fast": {
        "$type": "duration",
        "$value": "150ms"
      },
      "base": {
        "$type": "duration",
        "$value": "300ms"
      },
      "expressive": {
        "$type": "duration",
        "$value": "750ms"
      }
    },
    "easing": {
      "standard": {
        "$type": "cubicBezier",
        "$value": [
          0.2,
          0,
          0,
          1
        ]
      },
      "expressive": {
        "$type": "cubicBezier",
        "$value": [
          0.16,
          1,
          0.3,
          1
        ]
      }
    }
  }
